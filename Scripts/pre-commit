#!/bin/bash
# Git pre-commit hook for QuotaBar
# Runs SwiftLint on staged .swift files

if ! command -v swiftlint &> /dev/null; then
    echo "⚠️  SwiftLint not installed. Run 'brew install swiftlint' or skip with --no-verify"
    exit 0
fi

# Get staged Swift files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$')

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

echo "🔍 Running SwiftLint on staged files..."

LINT_RESULT=0
while IFS= read -r file; do
    if [ -f "$file" ]; then
        swiftlint lint --path "$file" --config .swiftlint.yml --quiet
        if [ $? -ne 0 ]; then
            LINT_RESULT=1
        fi
    fi
done <<< "$STAGED_FILES"

if [ $LINT_RESULT -ne 0 ]; then
    echo ""
    echo "❌ SwiftLint found issues. Fix them or commit with --no-verify to skip."
    exit 1
fi

echo "✅ SwiftLint passed"
exit 0
